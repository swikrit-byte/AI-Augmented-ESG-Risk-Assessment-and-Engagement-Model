# Copy this file to .env and fill in your key
# cp .env.example .env

CLAUDE_API_KEY=your-anthropic-api-key-here

# ─────────────────────────────────────────────
# AUTH CONFIG
# Leave provider blocks blank to run that flow in DEV MODE (no secrets needed).
# Fill them in to go live. See AUTH_SETUP.md for step-by-step instructions.
# ─────────────────────────────────────────────

# Base URL the app is served from (used for OAuth redirect URIs)
APP_BASE_URL=http://localhost:8000

# Session signing secret — generate a real one with:  openssl rand -hex 32
JWT_SECRET=dev-insecure-change-me
JWT_TTL_SECONDS=604800

# Email delivery (Gmail App Password recommended). Blank = DEV MODE (code logged + shown).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=ESGIntel

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# X / Twitter OAuth 2.0 (https://developer.x.com → Project → OAuth 2.0 client)
X_CLIENT_ID=
X_CLIENT_SECRET=

